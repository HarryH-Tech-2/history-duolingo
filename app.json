{
  "expo": {
    "name": "History Hero",
    "slug": "chronos",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B0F1C"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chronos.history"
    },
    "android": {
      "package": "com.chronos.history",
      "adaptiveIcon": {
        "backgroundColor": "#0B0F1C"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
